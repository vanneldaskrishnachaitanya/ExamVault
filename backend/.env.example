# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/vnrvjiet_repo
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/vnrvjiet_repo
MONGODB_URI=mongodb://localhost:27017/vnrvjiet_repo

# ── Firebase Admin SDK ───────────────────────────────────────────────────────
# 1. Go to Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key" → download JSON
# 3. Copy values from that JSON into the three variables below
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key exactly — keep the quotes, escape newlines as \n
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEow...\n-----END RSA PRIVATE KEY-----\n"

# ── Domain Restriction ───────────────────────────────────────────────────────
ALLOWED_DOMAIN=vnrvjiet.in

# ── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=25

# ── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
