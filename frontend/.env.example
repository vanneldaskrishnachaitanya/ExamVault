# Firebase Web App Config
# Get these from Firebase Console → Project Settings → Your Apps → Web App
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Backend API base URL
VITE_API_BASE_URL=http://localhost:5000

# Allowed email domain (enforced client-side; always also enforced server-side)
VITE_ALLOWED_DOMAIN=vnrvjiet.in

# Demo faculty login (optional)
VITE_DEMO_FACULTY_EMAIL=faculty.demo@vnrvjiet.in
VITE_DEMO_FACULTY_PASSWORD=Faculty@123
